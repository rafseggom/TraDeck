/* Based on https://github.com/tsconfig/bases/blob/501da2bcd640cf95c95805783e1012b992338f28/bases/node22.json */

{
  "compilerOptions": {
    "lib": ["es2023"],
    "target": "es2022",
    "module": "node16",
    "moduleResolution": "node16",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["mocha", "chai", "node"],
    "outDir": "dist"

  },
  "include": [
    "test/**/*.ts",
    "scripts/**/*.ts",
    "ignition/**/*.ts",
    "hardhat.config.ts"
  ]
}